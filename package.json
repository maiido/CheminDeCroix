{
  "name": "chemindecroix",
  "version": "1.0.0",
  "description": "Application de suivi des présences pour crèche parentale",
  "main": "dist-electron/main.js",
  "author": "CheminDeCroix",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build:win": "npm run electron:build && electron-builder --win",
    "build:mac": "npm run electron:build && electron-builder --mac && bash scripts/add-mac-readme.sh",
    "build:linux": "npm run electron:build && electron-builder --linux",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "exceljs": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.chemindecroix.app",
    "productName": "CheminDeCroix",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [{"target": "zip", "arch": ["x64", "arm64"]}],
      "category": "public.app-category.productivity"
    }
  }
}
