{
  "name": "chemindecroix",
  "version": "1.0.0",
  "description": "Application de suivi des présences pour crèche parentale",
  "main": "dist-electron/main.js",
  "author": "CheminDeCroix",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build:win": "npm run electron:build && electron-builder --win --publish never",
    "build:mac": "npm run electron:build && electron-builder --mac --publish never && bash scripts/add-mac-readme.sh",
    "build:linux": "npm run electron:build && electron-builder --linux AppImage --publish never",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "exceljs": "^4.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "wait-on": "^9.0.0"
  },
  "build": {
    "appId": "com.chemindecroix.app",
    "productName": "CheminDeCroix",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    }
  }
}
